rules_version = '2';
// Lotus Hub — Firestore security rules.
// Paste these into Firebase console → Firestore → Rules (or deploy via CLI).
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }

    // Rating/verification fields are owned by the server (Cloud Functions write
    // them with the Admin SDK, which bypasses these rules). Clients must never
    // set or change them, or anyone could fake a "verified" DUPR or Lotus Score.
    function protectedUserFields() {
      return ['duprLinked', 'duprId', 'duprEmail', 'homeRatingDoubles',
              'homeRatingSingles', 'duprSyncedAt', 'lotusScore'];
    }

    // Profiles: anyone signed in can read (to show names/ratings on rosters);
    // only the owner can write their own doc — and only the non-protected fields.
    // duprManual (the self-reported rating) IS client-writable on purpose.
    match /users/{uid} {
      allow read: if signedIn();
      // On create the doc may only carry the empty/false defaults for protected
      // fields (that's what the client's ensureUserDoc writes on first sign-in).
      allow create: if isSelf(uid)
        && request.resource.data.get('duprLinked', false) == false
        && request.resource.data.get('duprId', null) == null
        && request.resource.data.get('homeRatingDoubles', null) == null
        && request.resource.data.get('homeRatingSingles', null) == null
        && request.resource.data.get('lotusScore', null) == null;
      // On update, none of the protected fields may change.
      allow update: if isSelf(uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(protectedUserFields());
      allow delete: if isSelf(uid);
    }

    // Sessions: readable by any signed-in user; created by any signed-in user
    // (must set themselves as organizer); only the organizer can edit/delete.
    match /sessions/{sessionId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.organizerUid == request.auth.uid;
      // The organizer can edit anything; everyone else may only touch the RSVP
      // bookkeeping fields (attendeeCount/status) that join/leave transactions set.
      allow update: if signedIn() && (
        resource.data.organizerUid == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['attendeeCount', 'status'])
      );
      allow delete: if signedIn() && resource.data.organizerUid == request.auth.uid;

      // RSVPs: you can only create/edit/delete your OWN rsvp doc; anyone signed
      // in can read the roster.
      match /rsvps/{uid} {
        allow read: if signedIn();
        allow write: if isSelf(uid);
      }

      // Games (recorded scores) for a session. Anyone signed in can read the
      // results; only the session's organizer can add/edit/remove them. These
      // feed player stats now and bridge to DUPR (matches) later.
      match /games/{gameId} {
        allow read: if signedIn();
        allow write: if signedIn() &&
          get(/databases/$(database)/documents/sessions/$(sessionId)).data.organizerUid == request.auth.uid;
      }
    }

    // Collection-group read of games so a player's cross-session stats
    // (games played / win rate) can be computed with one query.
    match /{path=**}/games/{gameId} {
      allow read: if signedIn();
    }

    // Matches are created/validated server-side (Cloud Functions) before being
    // pushed to DUPR — clients get read-only access.
    match /matches/{matchId} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}
